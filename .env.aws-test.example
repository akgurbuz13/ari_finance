# ==============================================================================
# Ova AWS Test Environment Configuration (Example)
# Copy to .env.aws-test and fill in values
# ==============================================================================

# ==============================================================================
# TR L1 CONFIGURATION
# ==============================================================================
TR_L1_RPC_URL=http://tr-validator-nlb.ova-dev.internal:9650/ext/bc/tr/rpc
TR_L1_CHAIN_ID=99999
TR_L1_BLOCKCHAIN_ID=<32-byte-hex-after-l1-creation>

# Contract addresses (populated after deployment)
TR_STABLECOIN_ADDRESS=
TR_TOKEN_HOME_ADDRESS=
TR_TOKEN_REMOTE_ADDRESS=
TR_BRIDGE_ADAPTER_ADDRESS=
TR_TIMELOCK_ADDRESS=
TR_VALIDATOR_MANAGER_ADDRESS=

# ==============================================================================
# EU L1 CONFIGURATION
# ==============================================================================
EU_L1_RPC_URL=http://eu-validator-nlb.ova-dev.internal:9650/ext/bc/eu/rpc
EU_L1_CHAIN_ID=99998
EU_L1_BLOCKCHAIN_ID=<32-byte-hex-after-l1-creation>

# Contract addresses (populated after deployment)
EU_STABLECOIN_ADDRESS=
EU_TOKEN_HOME_ADDRESS=
EU_TOKEN_REMOTE_ADDRESS=
EU_BRIDGE_ADAPTER_ADDRESS=
EU_TIMELOCK_ADDRESS=
EU_VALIDATOR_MANAGER_ADDRESS=

# ==============================================================================
# TELEPORTER CONFIGURATION
# ==============================================================================
TELEPORTER_REGISTRY_ADDRESS=0xF86Cb19Ad8405AEFa7d09C778215D2Cb6eBfB228
TELEPORTER_MESSENGER_ADDRESS=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf

# ==============================================================================
# WALLET CONFIGURATION (DO NOT COMMIT REAL KEYS)
# ==============================================================================
DEPLOYER_PRIVATE_KEY=<your-deployer-key>
MINTER_PRIVATE_KEY=<your-minter-key>
BRIDGE_OPERATOR_PRIVATE_KEY=<your-bridge-operator-key>
TREASURY_ADDRESS=<your-treasury-address>

# ==============================================================================
# SERVICE CONFIGURATION
# ==============================================================================
CORE_BANKING_API_URL=http://localhost:8080
BLOCKCHAIN_SERVICE_API_URL=http://localhost:8081
INTERNAL_API_KEY=<generate-secure-key>

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DATABASE_URL=jdbc:postgresql://localhost:5432/ova
DATABASE_USERNAME=ova
DATABASE_PASSWORD=<your-db-password>
REDIS_URL=redis://localhost:6379

# ==============================================================================
# MONITORING
# ==============================================================================
BLOCKCHAIN_DEBUG_LOGGING=true
RECONCILIATION_SCHEDULE=0 0 2 * * *
ALERT_WEBHOOK_URL=
